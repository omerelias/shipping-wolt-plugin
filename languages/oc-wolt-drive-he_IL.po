#. Plugin Name of the plugin
#: oc-wolt-drive.php
msgid "OC Wolt Drive"
msgstr "OC Wolt Drive"

#. Plugin URI of the plugin
#: oc-wolt-drive.php
msgid "https://github.com/omerelias/shipping-wolt-plugin"
msgstr "https://github.com/omerelias/shipping-wolt-plugin"

#. Description of the plugin
#: oc-wolt-drive.php
msgid ""
"Wolt Drive courier integration for the OC Advanced Shipping plugin. Adds "
"live pricing at checkout, automatic + manual delivery dispatch to Wolt, JWT-"
"signed status webhooks, and an admin console."
msgstr ""
"אינטגרציית Wolt Drive לתוסף OC Advanced Shipping. כולל תמחור משלוחים בזמן "
"אמת בצ׳קאוט, שליחת משלוחים אוטומטית או ידנית לוולט, webhooks חתומים ב-JWT, "
"וקונסולת אדמין."

#. Author of the plugin
#: oc-wolt-drive.php
msgid "Omer Elias"
msgstr "עומר אליאס"

