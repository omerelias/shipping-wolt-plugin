msgstr "מחובר. וולט החזירו %d אזורי חלוקה."

#: includes/class-ocws-wolt-admin.php:105
msgid "Connection failed."
msgstr "החיבור נכשל."

#: includes/class-ocws-wolt-admin.php:106
